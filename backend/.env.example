# 孙大圣量化交易系统 - 环境变量模板
# 复制此文件为 .env 并填入实际值

# 应用配置
APP_NAME=孙大圣量化交易系统
APP_VERSION=0.1.0
DEBUG=false

# 数据库配置
DATABASE_URL=sqlite+aiosqlite:///./sundasheng.db

# Redis配置
REDIS_URL=redis://localhost:6379/0

# 币安API配置
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
BINANCE_TESTNET=true

# TOMAS-AGI配置
TOMAS_TRANSLATOR_URL=http://localhost:8001/api/translator
TOMAS_WRITER_URL=http://localhost:8002/api/writer

# OpenAI配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_BASE_URL=https://api.openai.com/v1

# 风控配置
RISK_MAX_POSITION_PCT=0.1
RISK_STOP_LOSS_PCT=0.05
RISK_TAKE_PROFIT_PCT=0.10
RISK_MAX_DRAWDOWN_PCT=0.20

# 行情采集配置
MARKET_FETCH_INTERVAL=60
MARKET_SYMBOLS=BTCUSDT,ETHUSDT

# Celery配置
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# CORS配置
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/sundasheng.log
